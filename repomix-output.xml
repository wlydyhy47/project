}

.notification-message {
  font-size: 12px;
  color: var(--gray-color);
  margin-bottom: 5px;
  line-height: 1.4;
  
  /* خاصية line-clamp مع دعم جميع المتصفحات */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  
  /* الخاصية القياسية للمستقبل */
  line-clamp: 2;
  
  /* دعم للمتصفحات القديمة */
  overflow: hidden;
  text-overflow: ellipsis;
  display: block; /* fallback للمتصفحات التي لا تدعم line-clamp */
  max-height: calc(1.4em * 2); /* ارتفاع سطرين كبديل */
  
  /* يمكن إضافة خاصية اضافية للمتصفحات الحديثة */
  @supports (line-clamp: 2) {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-clamp: 2;
    max-height: none;
  }
}

